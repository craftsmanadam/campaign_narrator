{
  "priority": 20,
  "request": {
    "method": "POST",
    "urlPath": "/v1/chat/completions",
    "bodyPatterns": [
      {
        "matchesJsonPath": {
          "expression": "$.messages[0].content",
          "contains": "Classify the player's input during a D&D 5e combat turn"
        }
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {"Content-Type": "application/json"},
    "bodyFileName": "combat-intent-combat-action-response.json"
  }
}
