{
  "priority": 50,
  "request": {
    "method": "POST",
    "urlPath": "/v1/chat/completions",
    "bodyPatterns": [
      {"matchesJsonPath": {"expression": "$.messages[0].content", "contains": "Classify the player's input into exactly one IntentCategory"}},
      {"matchesJsonPath": {"expression": "$.messages[1].content", "contains": "what happened"}}
    ]
  },
  "response": {"status": 200, "headers": {"Content-Type": "application/json"}, "bodyFileName": "player-intent-what-happened-response.json"}
}
