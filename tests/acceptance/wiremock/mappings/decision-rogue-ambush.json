{
  "priority": 5,
  "request": {
    "method": "POST",
    "urlPath": "/v1/chat/completions",
    "bodyPatterns": [
      {"matchesJsonPath": {"expression": "$.messages[0].content", "contains": "Choose the next encounter orchestration step"}},
      {"matchesJsonPath": {"expression": "$.messages[1].content", "contains": "ambush"}}
    ]
  },
  "response": {"status": 200, "headers": {"Content-Type": "application/json"}, "bodyFileName": "decision-rogue-ambush-response.json"}
}
