{
  "priority": 5,
  "request": {
    "method": "POST",
    "urlPath": "/v1/chat/completions",
    "bodyPatterns": [
      {"matchesJsonPath": {"expression": "$.messages[1].content", "contains": "\"purpose\": \"combat_turn_result\""}},
      {"matchesJsonPath": {"expression": "$.messages[1].content", "contains": "Sneak Attack: the dagger"}}
    ]
  },
  "response": {"status": 200, "headers": {"Content-Type": "application/json"}, "bodyFileName": "narration-rogue-sneak-attack-response.json"}
}
