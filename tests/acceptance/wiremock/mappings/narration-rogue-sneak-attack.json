{
  "priority": 5,
  "request": {
    "method": "POST",
    "urlPath": "/v1/responses",
    "bodyPatterns": [
      {
        "matchesJsonPath": {
          "expression": "$.input",
          "contains": "\"purpose\": \"combat_turn_result\""
        }
      },
      {
        "matchesJsonPath": {
          "expression": "$.input",
          "contains": "Sneak Attack: the dagger"
        }
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "bodyFileName": "narration-rogue-sneak-attack-response.json"
  }
}
