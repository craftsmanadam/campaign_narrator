{
  "priority": 10,
  "request": {
    "method": "POST",
    "urlPath": "/v1/chat/completions",
    "bodyPatterns": [
      {"matchesJsonPath": {"expression": "$.messages[0].content", "contains": "Classify the player's input into exactly one IntentCategory"}},
      {"matchesJsonPath": {"expression": "$.messages[1].content", "contains": "I charge the goblins and attack with my longsword."}}
    ]
  },
  "response": {"status": 200, "headers": {"Content-Type": "application/json"}, "bodyFileName": "decision-hostile-response.json"}
}
