{
  "priority": 20,
  "request": {
    "method": "POST",
    "urlPath": "/v1/chat/completions",
    "bodyPatterns": [
      {"matchesJsonPath": {"expression": "$.messages[1].content", "contains": "\"purpose\": \"recap_response\""}},
      {"matchesJsonPath": {"expression": "$.messages[1].content", "contains": "Outcome: de-escalated"}}
    ]
  },
  "response": {"status": 200, "headers": {"Content-Type": "application/json"}, "bodyFileName": "narration-recap-deescalated-response.json"}
}
