# ── Data storage ───────────────────────────────────────────────────────────────
DATA_ROOT=tmp/data_store

# ── LLM (OpenAI) ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
# OPENAI_API_KEY is loaded from .env.secrets — do not put it here.

# ── Embeddings (Ollama still handles embeddings locally) ───────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434

# ── LanceDB ────────────────────────────────────────────────────────────────────
# Leave empty to use DATA_ROOT/memory/lancedb/
LANCEDB_PATH=
