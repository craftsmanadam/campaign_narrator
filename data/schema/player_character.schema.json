{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Player Character State",
  "type": "object",
  "required": ["character_id", "name", "level", "hp", "ac", "inventory", "status"],
  "properties": {
    "character_id": { "type": "string" },
    "name": { "type": "string" },
    "level": { "type": "integer" },
    "hp": {
      "type": "object",
      "required": ["current", "max"],
      "properties": {
        "current": { "type": "integer" },
        "max": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "ac": { "type": "integer" },
    "inventory": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
