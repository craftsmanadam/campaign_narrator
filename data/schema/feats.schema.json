{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Feat Collection",
  "type": "object",
  "required": ["feat_categories", "feats"],
  "properties": {
    "feat_categories": {
      "type": "array",
      "items": { "type": "string" }
    },
    "feats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["feat_id", "name", "category", "benefit_ids", "repeatable"],
        "properties": {
          "feat_id": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "prerequisite": { "type": "string" },
          "spell_list": { "type": "string" },
          "benefit_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "repeatable": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
