{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Invocation Collection",
  "type": "object",
  "required": ["invocations"],
  "properties": {
    "invocations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["invocation_id", "name", "prerequisites", "repeatable", "summary"],
        "properties": {
          "invocation_id": { "type": "string" },
          "name": { "type": "string" },
          "prerequisites": {
            "type": "array",
            "items": { "type": "string" }
          },
          "repeatable": { "type": "boolean" },
          "summary": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
