{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Subclass Collection",
  "type": "object",
  "required": ["subclasses"],
  "properties": {
    "subclasses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subclass_id", "class_id", "name", "entry_level"],
        "properties": {
          "subclass_id": { "type": "string" },
          "class_id": { "type": "string" },
          "name": { "type": "string" },
          "entry_level": { "type": "integer" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
