{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Quest Collection",
  "type": "object",
  "required": ["quests"],
  "properties": {
    "quests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "quest_id",
          "name",
          "status",
          "giver_npc_id",
          "location_id",
          "steps"
        ],
        "properties": {
          "quest_id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "giver_npc_id": { "type": "string" },
          "location_id": { "type": "string" },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["step_id", "description"],
              "properties": {
                "step_id": { "type": "string" },
                "description": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
