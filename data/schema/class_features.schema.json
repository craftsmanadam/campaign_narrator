{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Class Feature Collection",
  "type": "object",
  "required": ["class_features"],
  "properties": {
    "class_features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["feature_id", "class_id", "level", "name", "summary"],
        "properties": {
          "feature_id": { "type": "string" },
          "class_id": { "type": "string" },
          "level": { "type": "integer" },
          "name": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
