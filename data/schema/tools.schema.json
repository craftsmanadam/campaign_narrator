{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tool Collection",
  "type": "object",
  "required": ["tools"],
  "properties": {
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "name", "category"],
        "properties": {
          "item_id": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
