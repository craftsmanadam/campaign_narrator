{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Class Collection",
  "type": "object",
  "required": ["classes"],
  "properties": {
    "classes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "class_id",
          "name",
          "hit_die",
          "primary_abilities",
          "saving_throws",
          "skill_choice_count",
          "skill_proficiency_options",
          "weapon_proficiencies",
          "armor_training",
          "tool_proficiencies",
          "spellcasting_ability",
          "is_spellcaster"
        ],
        "properties": {
          "class_id": { "type": "string" },
          "name": { "type": "string" },
          "hit_die": { "type": "string" },
          "primary_abilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "saving_throws": {
            "type": "array",
            "items": { "type": "string" }
          },
          "skill_choice_count": { "type": "integer" },
          "skill_proficiency_options": {
            "type": "array",
            "items": { "type": "string" }
          },
          "weapon_proficiencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "armor_training": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tool_proficiencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "spellcasting_ability": {
            "type": ["string", "null"]
          },
          "is_spellcaster": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
