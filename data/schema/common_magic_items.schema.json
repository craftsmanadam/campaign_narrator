{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Common Magic Item Collection",
  "type": "object",
  "required": ["magic_items"],
  "properties": {
    "magic_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "name", "rarity", "description"],
        "properties": {
          "item_id": { "type": "string" },
          "name": { "type": "string" },
          "rarity": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
