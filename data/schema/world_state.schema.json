{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "World Runtime State",
  "type": "object",
  "required": [
    "current_session",
    "current_location_id",
    "active_quest_ids",
    "quest_progress",
    "discovered_npc_ids",
    "discovered_location_ids",
    "flags"
  ],
  "properties": {
    "current_session": { "type": "integer" },
    "current_location_id": { "type": "string" },
    "active_quest_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "quest_progress": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "discovered_npc_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "discovered_location_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "flags": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    }
  },
  "additionalProperties": false
}
