{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Giant Collection",
  "type": "object",
  "required": ["monsters"],
  "properties": {
    "monsters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["monster_id", "name", "monster_type", "challenge_rating", "armor_class", "hit_points"],
        "properties": {
          "monster_id": { "type": "string" },
          "name": { "type": "string" },
          "monster_type": { "type": "string" },
          "challenge_rating": { "type": ["string", "number"] },
          "armor_class": { "type": "integer" },
          "hit_points": { "type": "integer" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
