{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Session Zero Seed",
  "type": "object",
  "required": ["player_prompt", "campaign_brief", "decisions"],
  "properties": {
    "player_prompt": { "type": "string" },
    "campaign_brief": { "type": "string" },
    "decisions": {
      "type": "object",
      "required": ["setting_style", "starting_level", "character_creation_mode"],
      "properties": {
        "setting_style": { "type": "string" },
        "starting_level": { "type": "integer" },
        "character_creation_mode": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
