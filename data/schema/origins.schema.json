{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Origin Collection",
  "type": "object",
  "required": ["origins"],
  "properties": {
    "origins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "origin_id",
          "name",
          "source_section",
          "ability_score_options",
          "feat_id",
          "skill_proficiencies",
          "tool_proficiency"
        ],
        "properties": {
          "origin_id": { "type": "string" },
          "name": { "type": "string" },
          "source_section": { "type": "string" },
          "ability_score_options": {
            "type": "array",
            "items": { "type": "string" }
          },
          "feat_id": { "type": "string" },
          "skill_proficiencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tool_proficiency": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
