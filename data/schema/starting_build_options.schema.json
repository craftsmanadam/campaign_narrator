{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Starting Build Option Collection",
  "type": "object",
  "required": ["starting_build_options"],
  "properties": {
    "starting_build_options": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["class_id", "skill_choice_count", "skill_options"],
        "properties": {
          "class_id": { "type": "string" },
          "skill_choice_count": { "type": "integer" },
          "skill_options": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
