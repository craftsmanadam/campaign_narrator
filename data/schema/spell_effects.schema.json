{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spell Effect Collection",
  "type": "object",
  "required": ["spell_effects"],
  "properties": {
    "spell_effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["spell_id"],
        "properties": {
          "spell_id": { "type": "string" },
          "save": { "type": "string" },
          "attack": { "type": "string" },
          "area": { "type": "string" },
          "concentration": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
