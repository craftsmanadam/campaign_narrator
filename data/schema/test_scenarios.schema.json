{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evaluation Scenarios",
  "type": "object",
  "required": ["scenarios"],
  "properties": {
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "scenario_id",
          "name",
          "steps",
          "expected_rule_topics",
          "expected_state_changes",
          "success_criteria"
        ],
        "properties": {
          "scenario_id": { "type": "string" },
          "name": { "type": "string" },
          "steps": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expected_rule_topics": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expected_state_changes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "success_criteria": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
