# ── Data storage ───────────────────────────────────────────────────────────────
# Directory for all runtime state: actors, campaign, modules, encounters, memory.
# Relative paths are resolved from the project root.
DATA_ROOT=var/data_store

# ── LLM ───────────────────────────────────────────────────────────────────────
# Default: local Ollama (CPU, ~7-10 t/s on Apple Silicon, ~48s first response).
# Switch provider at runtime: make run_local ARGS="--env openai"
LLM_PROVIDER=ollama
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=orieg/gemma3-tools:12b-ft-v2
# Ollama does not validate API keys; this value is required by the adapter but unused.
OPENAI_API_KEY=ollama

# ── Embeddings ─────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434

# ── LanceDB ────────────────────────────────────────────────────────────────────
# Leave empty to use DATA_ROOT/memory/lancedb/
LANCEDB_PATH=

# ── Logging ────────────────────────────────────────────────────────────────────
# Set to true to print WARNING+ log messages to the console in addition to the
# rotating log file at <DATA_ROOT>/logs/campaignnarrator.log
CONSOLE_LOGGING=false

# ── GPU (optional) ─────────────────────────────────────────────────────────────
# To enable GPU acceleration, add the following to the ollama service in
# docker-compose.local.yml:
#
#   deploy:
#     resources:
#       reservations:
#         devices:
#           - driver: nvidia
#             count: all
#             capabilities: [gpu]
#
# Suggested models by hardware:
#   CPU only (Apple Silicon):  OPENAI_MODEL=orieg/gemma3-tools:12b-ft-v2
#   GPU (16 GB+):              OPENAI_MODEL=qwen2.5:14b
#   GPU (48 GB+):              OPENAI_MODEL=qwen2.5:72b
#
# ── Docker memory ──────────────────────────────────────────────────────────────
# The 12B model requires ~10.2 GiB (7.6 GiB weights + 2.5 GiB KV cache).
# Docker Desktop must be configured with at least 12 GB RAM; 20 GB recommended.
#
# ── Port conflict ──────────────────────────────────────────────────────────────
# If you already have Ollama running outside Docker on port 11434,
# either stop it before running make run_local, or change the port mapping in
# docker-compose.local.yml and update OPENAI_BASE_URL / EMBEDDING_BASE_URL.
